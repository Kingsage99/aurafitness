# Copy this file to .env and fill in your keys
# Never commit .env to git

# Supabase (backend: auth, profiles, social, storage)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic API (Claude Haiku — chat coach, meal recipes, food lookup)
# DEV FALLBACK ONLY: production calls go through the claude-proxy Supabase
# Edge Function; the key lives there as a Supabase secret.
# Get from: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# Web Push (real OS-level notifications) — public VAPID key, safe to expose.
# The matching private key lives only as a Supabase Edge Function secret
# (VAPID_PRIVATE_KEY), never shipped to the browser.
VITE_VAPID_PUBLIC_KEY=

# Stripe (MissVfit Pro subscription) — Price IDs are public identifiers, safe to
# expose. Create them once in the Stripe Dashboard → Products → MissVfit Pro.
# The secret key + webhook signing secret live only as Supabase Edge Function
# secrets (STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET), never shipped here.
VITE_STRIPE_PRICE_MONTHLY=
VITE_STRIPE_PRICE_ANNUAL=

# Stripe (Store → Gems tab, one-time payments) — same rules as above: create
# these as one-time (not recurring) Prices in the Stripe Dashboard → Products
# → MissVfit Gems. The gem amount each one credits is fixed server-side in the
# stripe-create-checkout Edge Function's own secrets (see below), NOT read
# from these — these client-side vars only need to match the same Price IDs.
VITE_STRIPE_PRICE_GEMS_100=
VITE_STRIPE_PRICE_GEMS_500=
VITE_STRIPE_PRICE_GEMS_1200=
VITE_STRIPE_PRICE_GEMS_2500=

# The stripe-create-checkout Edge Function ALSO needs its own copies of these
# 4 Price IDs as Supabase secrets (same values as above), so it can map each
# one to a fixed gem amount server-side — never trust a client-supplied gem
# amount. Set as Supabase secrets (not here): STRIPE_PRICE_GEMS_100,
# STRIPE_PRICE_GEMS_500, STRIPE_PRICE_GEMS_1200, STRIPE_PRICE_GEMS_2500.
